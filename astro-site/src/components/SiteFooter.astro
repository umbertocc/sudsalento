---
const { guideHref = '/sudsalento/spiagge-salento', place = 'Lecce, Puglia', placeHtml } = Astro.props;
---
<footer class="footer">
  <div class="footer-container">
    <div class="footer-section">
      <h3>🏖️ Spiagge del Salento</h3>
      <p>Portale dedicato al Spiagge del Salento: scopri spiagge, eventi, attività e appartamenti in affitto nelle località più belle della costa ionica salentina.</p>
      <p style="margin-top: 15px;">📍 Spiagge del Salento<br />{placeHtml ? <span set:html={placeHtml} /> : place}</p>
    </div>
    <div class="footer-section">
      <h3>🔗 Link Utili</h3>
      <a href="/sudsalento/">Home</a>
      <a href="https://torrepalivacanze.it/">I Nostri Appartamenti</a>
      <a href={guideHref}>Guida Spiagge</a>
      <a href="/sudsalento/pescoluse">Pescoluse</a>
      <a href="/sudsalento/torre-pali">Torre Pali</a>
      <a href="/sudsalento/lido-marini">Lido Marini</a>
      <a href="/sudsalento/torre-vado">Torre Vado</a>
      <a href="/sudsalento/eventi-salento">Eventi e Tradizioni</a>
      <a href="/sudsalento/contatti">Contatti</a>
      <a href="/sudsalento/privacy">Privacy Policy</a>
    </div>
    <div class="footer-section">
      <h3>Contatti</h3>
      <p>📞 <a href="tel:+393804580135">+39 380 458 01 35</a></p>
      <p>📧 <strong>info@spiaggedelsalento.it</strong></p>
      <p>💬 <a href="https://wa.me/393804580135?text=Ciao!%20Vorrei%20informazioni%20sul%20Sud%20Salento%20e%20sugli%20appartamenti%20disponibili" target="_blank">WhatsApp</a></p>
      <p style="margin-top: 15px;">Orario: 09:00 - 20:00<br />Risposta entro 1 ora</p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2026 Spiagge del Salento. Tutti i diritti riservati.</p>
  </div>
</footer>

<style>
.footer { background: #0f172a; color: white; padding: 46px 26px 22px; margin-top: 56px; position: relative; }
.footer::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, #0ea5e9 0%, #0284c7 50%, #38bdf8 100%); opacity: 0.85; }
.footer-container { max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 38px; }
.footer-section h3 { margin-bottom: 16px; color: #f8fafc; font-weight: 700; font-size: 1.05em; }
.footer-section p { color: #cbd5e1; font-size: 0.93em; line-height: 1.7; margin-bottom: 9px; }
.footer-section a { color: #cbd5e1; font-size: 0.93em; line-height: 1.7; text-decoration: none; display: block; margin-bottom: 7px; transition: color 0.2s ease; }
.footer-section a:hover { color: #7dd3fc; }
.footer-bottom { text-align: center; margin-top: 28px; padding-top: 18px; border-top: 1px solid rgba(148, 163, 184, 0.24); color: #94a3b8; font-size: 0.88em; }

@media (max-width: 900px) {
  .footer-container { gap: 24px; }
}

@media (max-width: 768px) {
  .footer { padding: 34px 18px 18px; }
  .footer-container { grid-template-columns: 1fr; gap: 20px; }
}
</style>

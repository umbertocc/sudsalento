---
const { guideHref = '/spiagge-salento' } = Astro.props;
---
<nav class="navbar">
  <div class="navbar-container">
    <a href="/sudsalento/" class="navbar-brand">🏖️ Spiagge del Salento</a>
    <div class="hamburger" onclick="toggleMenu()">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <ul class="navbar-menu" id="navbarMenu">
      <li><a href="/sudsalento/" onclick="closeMenu()">Home</a></li>
      <li class="dropdown">
        <span class="dropdown-toggle" style="color: #4a5568; font-weight: 500;">Spiagge</span>
        <div class="dropdown-menu">
          <a href={guideHref} onclick="closeMenu()">🏖️ Guida Spiagge</a>
          <a href="/sudsalento/pescoluse" onclick="closeMenu()">Pescoluse</a>
          <a href="/sudsalento/torre-pali" onclick="closeMenu()">Torre Pali</a>
          <a href="/sudsalento/lido-marini" onclick="closeMenu()">Lido Marini</a>
          <a href="/sudsalento/torre-vado" onclick="closeMenu()">Torre Vado</a>
          <a href="/sudsalento/santa-maria-di-leuca" onclick="closeMenu()">Santa Maria di Leuca</a>
          <a href="/sudsalento/torre-mozza" onclick="closeMenu()">Torre Mozza</a>
          <a href="/sudsalento/torre-san-giovanni" onclick="closeMenu()">Torre San Giovanni</a>
          <a href="/sudsalento/marina-di-felloniche" onclick="closeMenu()">Marina di Felloniche</a>
        </div>
      </li>
      <li><a href="/sudsalento/eventi-salento" onclick="closeMenu()">Eventi & Attività</a></li>
      <li><a href="/sudsalento/contatti" onclick="closeMenu()">Contatti</a></li>
    </ul>
  </div>
</nav>

<style>
.navbar { position: fixed; top: 0; left: 0; right: 0; background: rgba(255, 255, 255, 0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(15, 23, 42, 0.08); box-shadow: 0 4px 14px rgba(15, 23, 42, 0.05); z-index: 1000; transition: box-shadow 0.25s ease, background-color 0.25s ease; }
.navbar:hover { box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08); }
.navbar-container { max-width: 1120px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; }
.navbar-brand { font-size: 1.28em; font-weight: 700; background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-decoration: none; letter-spacing: 0.1px; }

.navbar-menu { display: flex; gap: 24px; list-style: none; margin: 0; padding: 0; }
.navbar-menu > li { position: relative; }
.navbar-menu a { color: #334155; text-decoration: none; font-weight: 500; transition: color 0.25s ease; position: relative; padding: 5px 0; display: block; }
.navbar-menu a::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 1.5px; background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%); transition: width 0.25s ease; }
.navbar-menu a:hover { color: #0ea5e9; }
.navbar-menu a:hover::after { width: 100%; }

.dropdown { position: relative; }
.dropdown-toggle { cursor: pointer; display: flex; align-items: center; gap: 5px; padding: 5px 0; }
.dropdown-toggle::before { content: '\25BC'; font-size: 0.7em; transition: transform 0.3s; }
.dropdown:hover .dropdown-toggle::before { transform: rotate(180deg); }
.dropdown-menu { position: absolute; top: 100%; left: 0; background: white; min-width: 220px; border: 1px solid rgba(15, 23, 42, 0.08); box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12); border-radius: 12px; padding: 12px 0; margin-top: 10px; opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all 0.25s ease; z-index: 1000; }
.dropdown:hover .dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
.dropdown-menu a { padding: 10px 18px; color: #334155; font-weight: 500; white-space: nowrap; }
.dropdown-menu a::after { display: none; }
.dropdown-menu a:hover { background: rgba(14, 165, 233, 0.08); color: #0ea5e9; }

.hamburger { display: none; flex-direction: column; cursor: pointer; }
.hamburger span { width: 24px; height: 2px; background: #334155; margin: 3px 0; transition: 0.3s; border-radius: 3px; }

@media (max-width: 768px) {
  .hamburger { display: flex; }
  .hamburger { flex-shrink: 0; }
  .navbar-brand { min-width: 0; max-width: calc(100% - 48px); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .navbar-container { padding: 14px 18px; }
  .navbar-menu { position: fixed; left: -100%; top: 66px; flex-direction: column; background: rgba(255, 255, 255, 0.98); backdrop-filter: blur(10px); width: 84%; max-width: 320px; height: calc(100vh - 66px); padding: 24px 18px; border-right: 1px solid rgba(15, 23, 42, 0.08); box-shadow: 6px 0 18px rgba(15, 23, 42, 0.08); transition: left 0.25s ease; gap: 0; }
  .navbar-menu.active { left: 0; }
  .navbar-menu li { margin: 0; padding: 0; border-bottom: 1px solid rgba(14, 165, 233, 0.1); width: 100%; }
  .navbar-menu a { display: block; font-size: 1.02em; padding: 13px 0; }
  .dropdown-menu { position: static; box-shadow: none; padding: 0 0 0 20px; margin: 0; opacity: 1; visibility: visible; transform: none; max-height: 0; overflow: hidden; transition: max-height 0.3s; background: transparent; }
  .dropdown.active .dropdown-menu { max-height: 960px; padding: 10px 0 10px 20px; }
  .dropdown-toggle { padding: 14px 0; display: block; width: 100%; }
  .dropdown-toggle::before { display: inline-block; }
  .dropdown.active .dropdown-toggle::before { transform: rotate(180deg); }
}

@media (max-width: 480px) {
  .navbar-container { padding: 13px 14px; }
  .navbar-brand { font-size: 1.15em; max-width: calc(100% - 40px); }
}
</style>

<script is:inline>
(() => {
  if (window.__siteNavInitialized) return;
  window.__siteNavInitialized = true;

  window.toggleMenu = function toggleMenu() {
    const menu = document.getElementById('navbarMenu');
    if (!menu) return;
    const isActive = menu.classList.toggle('active');
    if (!isActive) {
      document.querySelectorAll('.dropdown.active').forEach((dropdown) => {
        dropdown.classList.remove('active');
      });
    }
  };

  window.closeMenu = function closeMenu() {
    const menu = document.getElementById('navbarMenu');
    if (!menu) return;
    menu.classList.remove('active');
    document.querySelectorAll('.dropdown.active').forEach((dropdown) => {
      dropdown.classList.remove('active');
    });
  };

  document.addEventListener('click', (event) => {
    const navbar = document.querySelector('.navbar');
    const menu = document.getElementById('navbarMenu');
    if (!navbar || !menu) return;
    if (!navbar.contains(event.target) && menu.classList.contains('active')) {
      menu.classList.remove('active');
      document.querySelectorAll('.dropdown.active').forEach((dropdown) => {
        dropdown.classList.remove('active');
      });
    }
  });

  document.addEventListener('click', (event) => {
    if (window.innerWidth > 768) return;
    const target = event.target;
    const targetElement = target instanceof Element ? target : target instanceof Node ? target.parentElement : null;
    const dropdownToggle = targetElement ? targetElement.closest('.dropdown-toggle') : null;
    if (!dropdownToggle) return;
    event.preventDefault();
    event.stopPropagation();
    const dropdown = dropdownToggle.closest('.dropdown');
    if (dropdown) {
      dropdown.classList.toggle('active');
    }
  });
})();
</script>

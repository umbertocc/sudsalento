<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Poppins', sans-serif; line-height: 1.6; color: #2d3748; background: radial-gradient(circle at 20% 10%, #eef7ff 0%, #f7fbff 35%, #ffffff 100%); padding-top: 84px; }
 /* Animazioni */
@keyframes fadeInUp {
 from { opacity: 0; transform: translateY(30px); }
 to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
 from { opacity: 0; }
 to { opacity: 1; }
}
@keyframes slideInLeft {
 from { opacity: 0; transform: translateX(-50px); }

<style>
@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Poppins', sans-serif; line-height: 1.65; color: #334155; background: radial-gradient(circle at 20% 10%, #fff7ed 0%, #fffaf4 45%, #ffffff 100%); padding-top: 76px; }
.container { max-width: 1120px; margin: 0 auto; padding: 26px 22px 30px; }
.back-btn { display: inline-block; background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%); color: white; padding: 10px 22px; border-radius: 999px; text-decoration: none; margin-bottom: 20px; font-weight: 600; box-shadow: 0 6px 16px rgba(234, 88, 12, 0.24); transition: all 0.25s ease; }
.back-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(234, 88, 12, 0.3); }
header { text-align: center; margin-bottom: 36px; padding: 62px 20px; background: linear-gradient(135deg, rgba(234, 88, 12, 0.95) 0%, rgba(194, 65, 12, 0.92) 100%); color: white; border-radius: 22px; border: 1px solid rgba(255, 255, 255, 0.3); box-shadow: 0 14px 34px rgba(234, 88, 12, 0.22); animation: fadeIn 0.8s ease-out; }
header h1 { font-size: clamp(2rem, 4.4vw, 3.1rem); margin-bottom: 12px; font-weight: 700; letter-spacing: -0.015em; text-shadow: 0 2px 10px rgba(0,0,0,0.16); }
.subtitle { font-size: clamp(1rem, 2vw, 1.25rem); color: rgba(255, 255, 255, 0.95); font-weight: 400; }
.content-section { background: #fffffffa; backdrop-filter: blur(8px); padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08); margin-bottom: 28px; border: 1px solid rgba(234, 88, 12, 0.12); animation: fadeInUp 0.6s ease-out; }
.content-section h2 { font-size: clamp(1.65rem, 3vw, 2.2rem); background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 20px; padding-left: 14px; border-left: 4px solid rgba(234, 88, 12, 0.42); font-weight: 700; }
.content-section h3 { font-size: 1.35em; color: #c2410c; margin: 22px 0 12px 0; font-weight: 600; }
.content-section p { font-size: 1.04em; line-height: 1.78; color: #475569; margin-bottom: 16px; text-align: left; }
.highlight-box { background: linear-gradient(135deg, rgba(234, 88, 12, 0.1) 0%, rgba(194, 65, 12, 0.1) 100%); border-left: 5px solid #ea580c; padding: 30px; border-radius: 20px; margin: 26px 0; box-shadow: 0 4px 15px rgba(234, 88, 12, 0.1); }
.highlight-box h3 { color: #ea580c; margin-top: 0; }
.info-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin: 24px 0; }
.info-card { background: linear-gradient(135deg, rgba(234, 88, 12, 0.04) 0%, rgba(194, 65, 12, 0.03) 100%); padding: 20px; border-radius: 14px; text-align: center; transition: all 0.25s ease; border: 1px solid rgba(234, 88, 12, 0.1); }
.info-card:hover { transform: translateY(-3px); box-shadow: 0 10px 22px rgba(234, 88, 12, 0.12); }
.info-card-icon { font-size: 2.2em; margin-bottom: 10px; }
.info-card h4 { background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 8px; font-size: 1.08em; font-weight: 600; }
.info-card p { color: #64748b; font-size: 0.95em; }
.features-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin: 25px 0; }
.feature-item { display: flex; align-items: center; gap: 15px; padding: 18px; background: rgba(234, 88, 12, 0.05); border-radius: 15px; border: 1px solid rgba(234, 88, 12, 0.1); transition: all 0.3s; }
.feature-item:hover { background: rgba(234, 88, 12, 0.1); transform: translateX(5px); }
.feature-item-icon { font-size: 1.5em; color: #ea580c; }
.cta-section { text-align: center; background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%); color: white; padding: 46px 26px; border-radius: 20px; margin-top: 26px; box-shadow: 0 14px 34px rgba(234, 88, 12, 0.24); animation: fadeInUp 0.8s ease-out; }
.cta-section h2 { font-size: clamp(1.6rem, 3.4vw, 2.2rem); margin-bottom: 14px; font-weight: 700; }
.cta-section p { font-size: 1.06em; margin-bottom: 20px; opacity: 0.95; }
.btn { display: inline-block; background: white; color: #ea580c; padding: 13px 26px; border-radius: 999px; text-decoration: none; font-weight: 600; margin: 8px; transition: all 0.25s ease; font-size: 1em; box-shadow: 0 8px 18px rgba(0, 0, 0, 0.14); }
.btn:hover { transform: translateY(-3px); box-shadow: 0 12px 35px rgba(0, 0, 0, 0.2); }
@media (max-width: 768px) {
.container { padding: 16px 12px 22px; }
header { padding: 44px 14px; border-radius: 16px; margin-bottom: 24px; }
header h1 { font-size: 1.95em; }
.subtitle { font-size: 1em; }
.info-grid, .features-list { grid-template-columns: 1fr; }
.content-section { padding: 24px 16px; border-radius: 16px; margin-bottom: 20px; }
}
@media (max-width: 480px) {
.container { padding: 14px 10px 20px; }
.btn { width: 100%; margin: 6px 0; text-align: center; }
}
</style>

---
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---
 <BaseLayout>
<Fragment slot="head">
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <meta name="robots" content="index, follow">
 <meta name="language" content="Italian">
 <meta name="author" content="Spiagge del Salento">
 <link rel="canonical" href="https://umbertocc.github.io/sudsalento/gallipoli">
 <title>Gallipoli Spiagge del Salento: Spiagge, Centro Storico e Vita Notturna 2026</title>
 <meta name="description" content="Scopri Gallipoli: spiagge Baia Verde, centro storico su isola, movida, eventi e guida completa per le tue vacanze nel Salento.">
 <meta name="keywords" content="gallipoli, salento, spiagge, baia verde, centro storico, movida, vacanze, puglia, mare cristallino">
 <!-- Open Graph Tags -->
 <meta property="og:title" content="Gallipoli Spiagge del Salento | Spiagge e Centro Storico">
 <meta property="og:description" content="Scopri Gallipoli: spiagge Baia Verde, centro storico su isola, movida e eventi nelle Spiagge del Salento.">
 <meta property="og:url" content="https://umbertocc.github.io/sudsalento/gallipoli">
 <meta property="og:type" content="website">
 <meta property="og:locale" content="it_IT">
 <meta property="og:site_name" content="Spiagge del Salento">
 <meta property="og:image" content="https://umbertocc.github.io/sudsalento/img/logo.png">
 <!-- Twitter Card Tags -->
 <meta name="twitter:card" content="summary_large_image">
 <meta name="twitter:title" content="Gallipoli | Spiagge, Centro Storico e Movida">
 <meta name="twitter:description" content="Guida completa a Gallipoli: Baia Verde, città vecchia sull'isola, eventi e vita notturna.">
 <meta name="twitter:image" content="https://umbertocc.github.io/sudsalento/img/logo.png">
 <link rel="icon" type="image/png" sizes="32x32" href="https://umbertocc.github.io/sudsalento/img/logo.png">
 <link rel="icon" type="image/png" sizes="192x192" href="https://umbertocc.github.io/sudsalento/img/logo.png">
 <link rel="apple-touch-icon" sizes="180x180" href="https://umbertocc.github.io/sudsalento/img/logo.png">
 <link rel="shortcut icon" href="https://umbertocc.github.io/sudsalento/img/logo.png">
 <link rel="manifest" href="/sudsalento/manifest.json">
 <link rel="preconnect" href="https://fonts.googleapis.com">
 <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
 <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
 <style>
@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Poppins', sans-serif; line-height: 1.65; color: #334155; background: radial-gradient(circle at 20% 10%, #ecfdf5 0%, #f5fff9 45%, #ffffff 100%); padding-top: 76px; }
.container { max-width: 1120px; margin: 0 auto; padding: 26px 22px 30px; }
.back-btn { display: inline-block; background: linear-gradient(135deg, #38a169 0%, #48bb78 100%); color: white; padding: 10px 22px; border-radius: 999px; text-decoration: none; margin-bottom: 20px; font-weight: 600; box-shadow: 0 6px 16px rgba(56, 161, 105, 0.24); transition: all 0.25s ease; }
.back-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(56, 161, 105, 0.3); }
header { text-align: center; margin-bottom: 36px; padding: 62px 20px; background: linear-gradient(135deg, rgba(56, 161, 105, 0.95) 0%, rgba(72, 187, 120, 0.92) 100%); color: white; border-radius: 22px; border: 1px solid rgba(255, 255, 255, 0.3); box-shadow: 0 14px 34px rgba(56, 161, 105, 0.22); animation: fadeIn 0.8s ease-out; }
header h1 { font-size: clamp(2rem, 4.4vw, 3.1rem); margin-bottom: 12px; font-weight: 700; letter-spacing: -0.015em; text-shadow: 0 2px 10px rgba(0,0,0,0.16); }
.subtitle { font-size: clamp(1rem, 2vw, 1.25rem); color: rgba(255, 255, 255, 0.95); font-weight: 400; }
.content-section { background: #fffffffa; backdrop-filter: blur(8px); padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08); margin-bottom: 28px; border: 1px solid rgba(56, 161, 105, 0.12); animation: fadeInUp 0.6s ease-out; }
.content-section h2 { font-size: clamp(1.65rem, 3vw, 2.2rem); background: linear-gradient(135deg, #38a169 0%, #48bb78 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 20px; padding-left: 14px; border-left: 4px solid rgba(56, 161, 105, 0.42); font-weight: 700; }
.content-section h3 { font-size: 1.35em; color: #2f855a; margin: 22px 0 12px 0; font-weight: 600; }
.content-section p { font-size: 1.04em; line-height: 1.78; color: #475569; margin-bottom: 16px; text-align: left; }
.highlight-box { background: linear-gradient(135deg, rgba(56, 161, 105, 0.1) 0%, rgba(72, 187, 120, 0.1) 100%); border-left: 5px solid #38a169; padding: 30px; border-radius: 20px; margin: 30px 0; box-shadow: 0 4px 15px rgba(56, 161, 105, 0.1); }
.highlight-box h3 { color: #38a169; margin-top: 0; font-weight: 600; }
.info-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin: 24px 0; }
.info-card { background: linear-gradient(135deg, rgba(56, 161, 105, 0.04) 0%, rgba(72, 187, 120, 0.03) 100%); padding: 20px; border-radius: 14px; text-align: center; transition: all 0.25s ease; border: 1px solid rgba(56, 161, 105, 0.1); }
.info-card:hover { transform: translateY(-3px); box-shadow: 0 10px 22px rgba(56, 161, 105, 0.12); }
.info-card-icon { font-size: 3em; margin-bottom: 15px; }
.info-card h4 { background: linear-gradient(135deg, #38a169 0%, #48bb78 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 8px; font-size: 1.12em; font-weight: 600; }
.info-card p { color: #64748b; font-size: 0.95em; }
.features-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin: 25px 0; }
.feature-item { display: flex; align-items: center; gap: 15px; padding: 18px; background: rgba(56, 161, 105, 0.05); border-radius: 15px; border: 1px solid rgba(56, 161, 105, 0.1); transition: all 0.3s; }
.feature-item:hover { background: rgba(56, 161, 105, 0.1); transform: translateX(5px); }
.feature-item-icon { font-size: 2em; color: #38a169; }
.cta-section { text-align: center; background: linear-gradient(135deg, #38a169 0%, #48bb78 100%); color: white; padding: 46px 26px; border-radius: 20px; margin-top: 26px; box-shadow: 0 14px 34px rgba(56, 161, 105, 0.24); animation: fadeInUp 0.8s ease-out; }
.cta-section h2 { font-size: clamp(1.6rem, 3.4vw, 2.2rem); margin-bottom: 14px; font-weight: 700; text-shadow: 0 2px 8px rgba(0,0,0,0.1); }
.cta-section p { font-size: 1.06em; margin-bottom: 20px; opacity: 0.95; font-weight: 400; }
.btn { display: inline-block; background: white; color: #38a169; padding: 13px 26px; border-radius: 999px; text-decoration: none; font-weight: 600; margin: 8px; transition: all 0.25s ease; font-size: 1em; box-shadow: 0 8px 18px rgba(0, 0, 0, 0.14); position: relative; overflow: hidden; }
.btn::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%); opacity: 0; transition: opacity 0.3s; }
.btn:hover { transform: translateY(-3px); box-shadow: 0 12px 35px rgba(0, 0, 0, 0.2); color: white; }
.btn:hover::before { opacity: 1; }
.btn span { position: relative; z-index: 1; }
@media (max-width: 768px) {
 .container { padding: 16px 12px 22px; }
 header { padding: 44px 14px; border-radius: 16px; margin-bottom: 24px; }
 header h1 { font-size: 1.95em; }
 .subtitle { font-size: 1em; }
 .info-grid { grid-template-columns: 1fr; }
 .features-list { grid-template-columns: 1fr; }
 .content-section { padding: 24px 16px; border-radius: 16px; margin-bottom: 20px; }
}
@media (max-width: 480px) {
 .container { padding: 14px 10px 20px; }
 .btn { width: 100%; margin: 6px 0; text-align: center; }
}
</style>
 </Fragment>
 <SiteNav guideHref="/sudsalento/spiagge-salento" />
 <div class="container">
 <a href="/sudsalento/" class="back-btn">← Torna alla homepage</a>
 <header>
 <h1>🏖️ Gallipoli</h1>
 <p class="subtitle">La Perla dello Ionio tra Spiagge, Storia e Movida</p>
 </header>
 <div class="content-section">
 <h2>🌊 Spiagge di Gallipoli</h2>
 <p>Gallipoli è famosa per le sue spiagge di sabbia bianca e mare cristallino. La più celebre è <strong>Baia Verde</strong>, con lidi attrezzati, beach bar e musica. Ideale per giovani, famiglie e chi cerca relax e divertimento.</p>
 <div class="info-grid">
 <div class="info-card">
 <div class="info-card-icon">🏖️</div>
 <h4>Baia Verde</h4>
 <p>Spiaggia tropicale, movida e party sulla sabbia.</p>
 </div>
 <div class="info-card">
 <div class="info-card-icon">🌅</div>
 <h4>Lido San Giovanni</h4>
 <p>Tramonti spettacolari e stabilimenti storici.</p>
 </div>
 <div class="info-card">
 <div class="info-card-icon">🏝️</div>
 <h4>Punta della Suina</h4>
 <p>Calette selvagge e acqua trasparente.</p>
 </div>
 </div>
 </div>
 <div class="content-section">
 <h2>🏰 Centro Storico</h2>
 <p>Il centro storico di Gallipoli sorge su un'isola collegata alla terraferma da un ponte. Qui trovi vicoli pittoreschi, chiese barocche, il Castello Angioino e il porto turistico. Da non perdere la passeggiata sulle mura e il mercato del pesce.</p>
 </div>
 <div class="content-section">
 <h2>🎉 Vita Notturna e Eventi</h2>
 <p>Gallipoli è la capitale della movida salentina: beach party, discoteche, locali sul mare e eventi musicali animano le serate estive. La città ospita festival, sagre e concerti per tutti i gusti.</p>
 </div>
 <div class="cta-section">
 <h2>Scopri Gallipoli</h2>
 <p>Vivi la magia di Gallipoli tra spiagge, storia e divertimento.</p>
 <a href="/sudsalento/" class="btn"><span>Appartamenti e Offerte</span></a>
 <a href="/sudsalento/contatti" class="btn"><span>Contattaci</span></a>
 </div>
 </div>
 <SiteFooter guideHref="/sudsalento/spiagge-salento" placeHtml="Gallipoli (LE)<br />Salento, Puglia" />
 </BaseLayout>
 


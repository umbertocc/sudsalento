.timeline { position: relative; padding: 30px 0; margin: 40px 0; }
.timeline::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, #0ea5e9 0%, #0284c7 100%); }
.timeline-item { display: flex; align-items: center; margin-bottom: 40px; position: relative; }
.timeline-item:nth-child(odd) { flex-direction: row; }
.timeline-item:nth-child(even) { flex-direction: row-reverse; }

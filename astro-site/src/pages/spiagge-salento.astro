.btn { display: inline-block; background: white; color: #0ea5e9; padding: 13px 26px; border-radius: 999px; text-decoration: none; font-weight: 600; margin: 8px; transition: all 0.25s ease; font-size: 1em; box-shadow: 0 8px 18px rgba(0, 0, 0, 0.14); position: relative; overflow: hidden; }

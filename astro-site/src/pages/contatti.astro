 header p { font-size: 1rem !important; margin-top: 10px !important; }
 .content-grid { grid-template-columns: 1fr; }
 .content-grid { gap: 24px; margin-bottom: 34px; }
 .contact-info, .contact-form { padding: 28px 20px; border-radius: 18px; }
 .contact-info h2, .contact-form h2 { font-size: 1.55em; margin-bottom: 20px; }
 .contact-method p { font-size: 1.02em; }
 .form-btn { padding: 14px 28px; font-size: 1.02em; }
 .footer-container { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {

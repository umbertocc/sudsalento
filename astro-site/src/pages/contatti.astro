<!-- Google Analytics (GA4) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-M0TEME57K0"></script>
<script>
 window.dataLayer = window.dataLayer || [];
 function gtag(){dataLayer.push(arguments);}
 gtag('js', new Date());
 gtag('config', 'G-M0TEME57K0');
</script>
<script>
// AJAX submission to Formspree to avoid redirect
document.addEventListener('DOMContentLoaded', function(){
 const form = document.getElementById('contactForm');
 const success = document.getElementById('successMsg');
 if (!form) return;
 form.addEventListener('submit', async (e) => {
 e.preventDefault();
 const data = new FormData(form);
 // Add reply-to so Formspree can send an autoresponse to the user
 const userEmail = (form.elements['email'] && form.elements['email'].value) || '';
 const userName = (form.elements['nome'] && form.elements['nome'].value) || 'Cliente';
 if (userEmail) {
 data.append('_replyto', userEmail);
 data.append('_email', userEmail); // Campo aggiuntivo per migliore deliverability
 }
 // Subject ottimizzato per evitare spam
 data.append('_subject', `Nuova Richiesta da ${userName} - Affitti Torre Pali`);
 // Template HTML per email più professionale
 data.append('_template', 'box');
 // Conferma automatica all'utente
 data.append('_autoresponse', 'Grazie per averci contattato! Abbiamo ricevuto la tua richiesta e ti risponderemo entro 1 ora. - Affitti Torre Pali');
 try {
 const resp = await fetch(form.action, {
 method: 'POST',
 headers: { 'Accept': 'application/json' },
 body: data
 });
 if (resp.ok) {
 success.style.display = 'block';
 success.scrollIntoView({ behavior: 'smooth', block: 'center' });
 form.reset();
 setTimeout(() => { success.style.display = 'none'; }, 7000);
 } else {
 const text = await resp.text();
 console.error('Formspree error', resp.status, text);
 alert('Si è verificato un errore durante l\'invio. Riprova più tardi.');
 }
 } catch (err) {
 console.error(err);
 alert('Errore di rete. Riprova più tardi.');
 }
 });
});
</script>
